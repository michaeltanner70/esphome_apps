# =============================================================================
#  Zentrale Secrets für ALLE Apps in diesem Repository
# -----------------------------------------------------------------------------
#  Kopiere diese Datei zu "secrets.yaml" (im Repo-Root) und trage echte Werte ein.
#  "secrets.yaml" ist via .gitignore vom Repository ausgeschlossen.
#
#  ESPHome findet diese Datei aus den App-Unterordnern heraus, da es secrets.yaml
#  auch im übergeordneten Verzeichnis sucht. Kompiliert wird vom Repo-Root aus,
#  z. B.:  esphome run omnilink-poolboy/omnilink-poolboy.yaml
# =============================================================================

# --- Gemeinsam (alle Apps) ---------------------------------------------------
wifi_ssid: "DEIN_WLAN_SSID"
wifi_password: "DEIN_WLAN_PASSWORT"

# Login für den lokalen Webserver (web_server: auth)
web_server_username: "admin"
web_server_password: "DEIN_WEB_PASSWORT"

# --- common/diagnostics.yaml : bekannte Access-Point-BSSIDs -------------------
# MAC-Adressen deiner APs für die Klartext-Auflösung (z. B. "🏠 EG West").
mac_bssid_ug: "00:00:00:00:00:00"
mac_bssid_garten: "00:00:00:00:00:00"
mac_bssid_dg: "00:00:00:00:00:00"
mac_bssid_eg_west: "00:00:00:00:00:00"
mac_bssid_eg_ost: "00:00:00:00:00:00"

# --- App: omnilink-poolboy ---------------------------------------------------
poolboy_api_key: "BASE64_ENCRYPTION_KEY_HIER"
poolboy_ota_key: "OTA_PASSWORT_HIER"
poolboy_fallback_ap_ssid: "OmniLink-PoolBoy"
poolboy_fallback_ap_password: "AP_FALLBACK_PASSWORT_HIER"
